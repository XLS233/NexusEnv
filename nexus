  nexus watcher status          # 查看 watcher 状态

配置文件: ~/.config/nexus/config
EOF
}

# ========== 主入口 ==========

case "${1:-help}" in
    connect)    shift; cmd_connect "$@" ;;
    disconnect) shift; cmd_disconnect "$@" ;;
    ssh)        shift; cmd_ssh "$@" ;;
    health)     cmd_health ;;
    restore)    shift; cmd_restore "$@" ;;
    watcher)    shift; cmd_watcher "$@" ;;
    status)     cmd_status ;;
    mount)      shift; cmd_mount "$@" ;;
    umount)     shift; cmd_umount "$@" ;;
    claude)     shift; cmd_claude "$@" ;;
    codex)      shift; cmd_codex "$@" ;;
    sync)       shift; cmd_sync "$@" ;;
    add)        shift; cmd_add "$@" ;;
    set-timeout) shift; cmd_set_timeout "$@" ;;
    init)       cmd_init ;;
    setup)      cmd_setup ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}未知命令: $1${NC}"
        cmd_help
        exit 1
        ;;
esac
