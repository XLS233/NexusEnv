#!/usr/bin/env bash
set -euo pipefail

# NexusEnv - 多机办公环境管理工具
# 通过 SSH ControlMaster 复用连接 + SSHFS 挂载远程文件系统

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# 加载配置库
source "$SCRIPT_DIR/lib/config.sh"

# 默认配置路径
SOCKET_DIR="$(cfg_socket_dir)"
MOUNT_BASE="$(cfg_mount_base)"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# 确保配置已加载
if ! cfg_ensure_loaded; then
    # 如果是 help 或 setup 命令，允许不带配置文件运行
    case "${1:-}" in
        help|--help|-h|setup|init) : ;;
        *)
            echo -e "${RED}错误: 未找到配置文件，请先运行: nexus setup 或 nexus init${NC}"
            exit 1
            ;;
    esac
fi

# 查询远程路径
get_remote_path() {
    local server="$1" target="$2"
    cfg_get_path "$server" "$target"
}

# 获取服务器支持的挂载目标
get_mount_targets() {
    local server="$1"
    cfg_get_mount_targets "$server"
}

# 从 ~/.ssh/config 中提取已定义的 Host（排除通配符和通用配置）
get_known_hosts() {
    grep -E "^Host [^*]" "$HOME/.ssh/config" 2>/dev/null | awk '{print $2}' | sort
}

# 检测 host 是否通过 ProxyJump/ProxyCommand 依赖另一个 host
_detect_proxy_dep() {
    local host="$1"
    local proxy
    proxy=$(ssh -G "$host" 2>/dev/null | awk '/^proxyjump /{print $2}')
    if [[ -n "$proxy" && "$proxy" != "none" ]]; then
        echo "$proxy"
        return
    fi
    local proxy_cmd
    proxy_cmd=$(ssh -G "$host" 2>/dev/null | awk '/^proxycommand /{$1=""; print}')
    if [[ -n "$proxy_cmd" ]]; then
        # 尝试从 ProxyCommand 中提取 host 名
        local dep
        dep=$(echo "$proxy_cmd" | sed -n 's/.*-W %h:%p[[:space:]]\+\([^[:space:]]\+\).*/\1/p; s/.*ssh[[:space:]]\+\([^[:space:]]\+\).*/\1/p' | head -1)
        [[ -n "$dep" ]] && echo "$dep"
    fi
}

# 获取指定 host 的 ControlPath socket 路径
get_socket_path() {
    local host="$1"
    # 从 ssh config 解析实际连接参数，构造 socket 路径
    local user port hostname
    user=$(ssh -G "$host" 2>/dev/null | awk '/^user /{print $2}')
    hostname=$(ssh -G "$host" 2>/dev/null | awk '/^hostname /{print $2}')
    port=$(ssh -G "$host" 2>/dev/null | awk '/^port /{print $2}')
    echo "$SOCKET_DIR/${user}@${hostname}-${port}"
}

# 检查指定 host 的连接状态
check_connection() {
    local host="$1"
    ssh -S "$(get_socket_path "$host")" -O check "$host" 2>/dev/null
}

cleanup_stale_socket() {
    local host="$1"
    local socket
    socket="$(get_socket_path "$host")"

    if [[ -e "$socket" ]] && ! check_connection "$host" 2>/dev/null; then
        rm -f "$socket"
        return 0
    fi

    return 1
}

list_nexus_mounts() {
    command -v mount &>/dev/null || return 0

    while IFS= read -r line; do
        [[ "$line" == *"$MOUNT_BASE"* ]] || continue

        local mount_point=""
        if [[ "$(uname)" == "Darwin" ]]; then
            mount_point=$(echo "$line" | sed 's/.* on //;s/ (.*//')
        else
            mount_point=$(echo "$line" | awk '{print $3}')
        fi

        [[ "$mount_point" == "$MOUNT_BASE"/* ]] || continue

        local remainder="${mount_point#"$MOUNT_BASE/"}"
        local host="${remainder%%/*}"
        local target="${remainder#"$host"}"
        target="${target#/}"

        printf '%s\t%s\t%s\n' "$host" "$target" "$mount_point"
    done < <(mount | grep -i "fuse\|sshfs" 2>/dev/null || true)
}

host_has_mounts() {
    local host="$1"

    while IFS=$'\t' read -r mount_host _ mount_point; do
        if [[ "$mount_host" == "$host" ]] && [[ -n "$mount_point" ]]; then
            return 0
        fi
    done < <(list_nexus_mounts)

    return 1
}

watcher_state_dir() {
    cfg_watcher_state_dir
}

watcher_pid_file() {
    echo "$(watcher_state_dir)/watcher.pid"
}

watcher_stale_dir() {
    echo "$(watcher_state_dir)/stale"
}

watcher_notice_dir() {
    echo "$(watcher_state_dir)/notice"
}

watcher_event_log() {
    echo "$(watcher_state_dir)/events.log"
}

restore_state_file() {
    echo "$(watcher_state_dir)/restore.state"
}

ensure_watcher_state_dir() {
    mkdir -p "$(watcher_stale_dir)" "$(watcher_notice_dir)"
    touch "$(restore_state_file)" "$(watcher_event_log)"
}

watcher_pid_is_running() {
    local pid="$1"
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

watcher_current_pid() {
    local pid_file
    pid_file="$(watcher_pid_file)"

    if [[ -f "$pid_file" ]]; then
        local pid
        pid="$(<"$pid_file")"
        if watcher_pid_is_running "$pid"; then
            echo "$pid"
            return 0
        fi
        rm -f "$pid_file"
    fi

    return 1
}

watcher_mark_stale() {
    local host="$1"
    local file
    file="$(watcher_stale_dir)/$host"

    if [[ ! -f "$file" ]]; then
        date +%s > "$file"
    fi
}

watcher_clear_stale() {
    local host="$1"
    rm -f "$(watcher_stale_dir)/$host"
}

watcher_stale_since() {
    local host="$1"
    local file
    file="$(watcher_stale_dir)/$host"
    [[ -f "$file" ]] || return 1
    cat "$file"
}

watcher_clear_all_stale() {
    rm -f "$(watcher_stale_dir)"/* 2>/dev/null || true
}

restore_record_mount() {
    local host="$1" target="$2" remote_path="$3" mount_point="$4" mode="$5"
    local file tmp
    file="$(restore_state_file)"
    tmp="${file}.tmp"

    ensure_watcher_state_dir
    awk -F '\t' -v host="$host" -v target="$target" '!(NF >= 2 && $1 == host && $2 == target)' "$file" > "$tmp" 2>/dev/null || true
    printf '%s\t%s\t%s\t%s\t%s\n' "$host" "$target" "$remote_path" "$mount_point" "$mode" >> "$tmp"
    mv "$tmp" "$file"
}

restore_remove_mount() {
    local host="$1" target="$2"
    local file tmp
    file="$(restore_state_file)"
    tmp="${file}.tmp"

    ensure_watcher_state_dir
    awk -F '\t' -v host="$host" -v target="$target" '!(NF >= 2 && $1 == host && $2 == target)' "$file" > "$tmp" 2>/dev/null || true
    mv "$tmp" "$file"
}

restore_clear_host() {
    local host="$1"
    local file tmp
    file="$(restore_state_file)"
    tmp="${file}.tmp"

    ensure_watcher_state_dir
    awk -F '\t' -v host="$host" '!(NF >= 1 && $1 == host)' "$file" > "$tmp" 2>/dev/null || true
    mv "$tmp" "$file"
}

restore_has_entries() {
    local host="${1:-}"
    local file
    file="$(restore_state_file)"
    [[ -f "$file" ]] || return 1

    if [[ -n "$host" ]]; then
        awk -F '\t' -v host="$host" 'NF >= 1 && $1 == host { found=1; exit } END { exit(found ? 0 : 1) }' "$file"
    else
        grep -q '[^[:space:]]' "$file" 2>/dev/null
    fi
}

restore_print_entries() {
    local host="${1:-}"
    local file
    file="$(restore_state_file)"
    [[ -f "$file" ]] || return 0

    if [[ -n "$host" ]]; then
        awk -F '\t' -v host="$host" 'NF >= 5 && $1 == host { print }' "$file"
    else
        awk -F '\t' 'NF >= 5 { print }' "$file"
    fi
}

watcher_notice_file() {
    local host="$1"
    echo "$(watcher_notice_dir)/$host"
}

watcher_notice_state() {
    local host="$1"
    local file
    file="$(watcher_notice_file "$host")"
    [[ -f "$file" ]] || return 1
    cat "$file"
}

watcher_set_notice_state() {
    local host="$1" state="$2"
    ensure_watcher_state_dir
    printf '%s\n' "$state" > "$(watcher_notice_file "$host")"
}

watcher_clear_notice_state() {
    local host="$1"
    rm -f "$(watcher_notice_file "$host")"
}

watcher_notice_transition() {
    local host="$1" new_state="$2" message="$3"
    local current_state=""

    if current_state="$(watcher_notice_state "$host" 2>/dev/null)"; then
        if [[ "$current_state" == "$new_state" ]]; then
            return 0
        fi
    fi

    echo -e "$message"
    printf '%s\t%s\t%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$host" "$new_state" >> "$(watcher_event_log)"
    watcher_set_notice_state "$host" "$new_state"
}

watcher_clear_all_notice_states() {
    rm -f "$(watcher_notice_dir)"/* 2>/dev/null || true
}

watcher_recent_events() {
    local log_file
    log_file="$(watcher_event_log)"
    [[ -f "$log_file" ]] || return 0
    tail -n 5 "$log_file" 2>/dev/null || true
}

watcher_clear_all_stale() {
    rm -f "$(watcher_stale_dir)"/* 2>/dev/null || true
}

watcher_host_probe() {
    local host="$1"
    ssh -o ConnectTimeout=5 "$host" "echo ok" &>/dev/null
}

watcher_start() {
    local force="${1:-false}"

    if [[ "$force" != "true" ]] && ! cfg_watcher_enabled; then
        return 0
    fi

    local pid
    if pid="$(watcher_current_pid)"; then
        return 0
    fi

    if ! list_nexus_mounts | grep -q .; then
        return 0
    fi

    ensure_watcher_state_dir
    nohup "$0" watcher run >/dev/null 2>&1 &
}

cmd_watcher() {
    local action="${1:-status}"
    local pid

    case "$action" in
        run)
            ensure_watcher_state_dir
            echo $$ > "$(watcher_pid_file)"
            trap 'rm -f "$(watcher_pid_file)"; watcher_clear_all_stale' EXIT INT TERM

            local interval grace
            interval="$(cfg_watcher_interval)"
            grace="$(cfg_watcher_grace)"

            while true; do
                local has_mounts=false
                local seen_hosts=" "
                local now
                now=$(date +%s)

                while IFS=$'\t' read -r host _ mount_point; do
                    [[ -n "$mount_point" ]] || continue
                    has_mounts=true

                    if [[ "$seen_hosts" == *" $host "* ]]; then
                        continue
                    fi
                    seen_hosts+="$host "

                    if check_connection "$host" 2>/dev/null; then
                        if watcher_stale_since "$host" >/dev/null 2>&1; then
                            watcher_notice_transition "$host" recovered "${GREEN}[watcher] ${host} 连接已恢复，取消自动卸载${NC}"
                        fi
                        watcher_clear_stale "$host"
                        continue
                    fi

                    watcher_mark_stale "$host"
                    watcher_notice_transition "$host" stale "${YELLOW}[watcher] ${host} 连接异常，已进入观察期 (${grace}s)${NC}"
                    local stale_since
                    stale_since="$(watcher_stale_since "$host")"
                    if [[ -z "$stale_since" ]]; then
                        continue
                    fi

                    if (( now - stale_since < grace )); then
                        continue
                    fi

                    if watcher_host_probe "$host"; then
                        watcher_notice_transition "$host" recovered "${GREEN}[watcher] ${host} 连接已恢复，取消自动卸载${NC}"
                        watcher_clear_stale "$host"
                        continue
                    fi

                    cmd_umount "$host" "" watcher_auto
                    watcher_notice_transition "$host" unmounted "${YELLOW}[watcher] ${host} 持续不可达，已自动卸载挂载；恢复后可运行 nexus restore ${host}${NC}"
                    watcher_clear_stale "$host"
                done < <(list_nexus_mounts)

                if ! $has_mounts; then
                    break
                fi

                for stale_file in "$(watcher_stale_dir)"/*; do
                    [[ -e "$stale_file" ]] || break
                    local stale_host
                    stale_host="$(basename "$stale_file")"
                    if [[ "$seen_hosts" != *" $stale_host "* ]]; then
                        rm -f "$stale_file"
                    fi
                done

                sleep "$interval"
            done
            ;;
        start)
            watcher_start true
            if pid="$(watcher_current_pid)"; then
                echo -e "${GREEN}[OK] watcher 运行中 (pid: ${pid})${NC}"
            else
                echo -e "${YELLOW}当前没有挂载，watcher 未启动${NC}"
            fi
            ;;
        stop)
            if pid="$(watcher_current_pid)"; then
                kill "$pid" 2>/dev/null || true
                rm -f "$(watcher_pid_file)"
                watcher_clear_all_stale
                echo -e "${GREEN}[OK] watcher 已停止${NC}"
            else
                echo -e "${YELLOW}watcher 未运行${NC}"
            fi
            ;;
        status)
            local interval grace
            interval="$(cfg_watcher_interval)"
            grace="$(cfg_watcher_grace)"

            if pid="$(watcher_current_pid)"; then
                echo -e "${GREEN}watcher 运行中${NC} (pid: ${pid}, interval: ${interval}s, grace: ${grace}s)"
            else
                echo -e "${YELLOW}watcher 未运行${NC}"
            fi

            local has_stale=false
            local now
            now=$(date +%s)
            for stale_file in "$(watcher_stale_dir)"/*; do
                [[ -e "$stale_file" ]] || break
                has_stale=true
                local host stale_since elapsed
                host="$(basename "$stale_file")"
                stale_since="$(<"$stale_file")"
                elapsed=$(( now - stale_since ))
                echo -e "  ${YELLOW}▲${NC} ${host} 已连续异常 ${elapsed}s / ${grace}s"
            done

            if ! $has_stale; then
                echo -e "  ${GREEN}无 stale host${NC}"
            fi

            local has_events=false
            while IFS=$'\t' read -r ts host state; do
                [[ -n "$ts" ]] || continue
                if ! $has_events; then
                    echo -e "  ${CYAN}最近事件:${NC}"
                    has_events=true
                fi
                echo -e "    ${ts} ${host} -> ${state}"
            done < <(watcher_recent_events)
            ;;
        *)
            echo -e "${RED}用法: nexus watcher <start|stop|status|run>${NC}"
            return 1
            ;;
    esac
}

# 更新 general section 中的 control_persist
set_control_persist() {
    local config_file="$1" persist="$2"
    python3 - "$config_file" "$persist" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
persist = sys.argv[2]
lines = path.read_text().splitlines()
out = []
in_general = False
updated = False
inserted = False

for line in lines:
    stripped = line.strip()
    if stripped.startswith('[') and stripped.endswith(']'):
        if in_general and not updated:
            out.append(f'control_persist = {persist}')
            updated = True
            inserted = True
        in_general = stripped == '[general]'
        out.append(line)
        continue

    if in_general and stripped.startswith('control_persist ='):
        if not updated:
            out.append(f'control_persist = {persist}')
            updated = True
        continue

    out.append(line)

if in_general and not updated:
    out.append(f'control_persist = {persist}')
    inserted = True

if not any(line.strip() == '[general]' for line in lines):
    if out and out[-1] != '':
        out.append('')
    out.extend(['[general]', f'control_persist = {persist}'])
    inserted = True

path.write_text('\n'.join(out) + '\n')
PY
}

validate_control_persist() {
    local value="$1"
    [[ "$value" =~ ^[1-9][0-9]*$ || "$value" == "yes" || "$value" == "forever" ]]
}

# ========== 子命令 ==========

cmd_connect() {
    local host="${1:?用法: nexus connect <host>}"
    local persist
    persist="$(cfg_control_persist)"

    # 检查依赖（跳板机场景）
    local dep
    dep="$(cfg_get_depends "$host")"
    if [[ -n "$dep" ]] && ! check_connection "$dep" 2>/dev/null; then
        echo -e "${YELLOW}${host} 依赖 ${dep}，正在先连接 ${dep}...${NC}"
        cmd_connect "$dep"
    fi

    echo -e "${CYAN}正在连接 ${host}...${NC}"
    echo -e "${YELLOW}请完成认证（可能需要2FA）${NC}"

    if cleanup_stale_socket "$host"; then
        echo -e "${YELLOW}检测到失效的 ControlMaster socket，已自动清理${NC}"
    fi

    ssh -o ControlMaster=yes -o ControlPersist="$persist" -S "$(get_socket_path "$host")" -fN "$host"

    if check_connection "$host"; then
        echo -e "${GREEN}[OK] ${host} 连接已建立，ControlMaster socket 已激活${NC}"
    else
        echo -e "${RED}[FAIL] ${host} 连接建立失败${NC}"
        return 1
    fi
}

cmd_disconnect() {
    local host="${1:?用法: nexus disconnect <host>}"

    if host_has_mounts "$host"; then
        echo -e "${CYAN}检测到 ${host} 仍有 SSHFS 挂载，先自动卸载...${NC}"
        cmd_umount "$host"
    fi

    restore_clear_host "$host"

    if check_connection "$host"; then
        ssh -S "$(get_socket_path "$host")" -O exit "$host" 2>/dev/null
        echo -e "${GREEN}[OK] ${host} 连接已关闭${NC}"
    else
        echo -e "${YELLOW}${host} 本来就没有活跃连接${NC}"
    fi
}

cmd_status() {
    echo -e "${CYAN}=== NexusEnv 连接状态 ===${NC}"
    echo ""

    # SSH 连接状态
    echo -e "${CYAN}[SSH ControlMaster]${NC}"
    local has_connection=false
    for host in $(cfg_get_servers); do
        cleanup_stale_socket "$host" >/dev/null 2>&1 || true

        if check_connection "$host" 2>/dev/null; then
            echo -e "  ${GREEN}●${NC} ${host} — 已连接"
            has_connection=true
        else
            echo -e "  ${RED}○${NC} ${host} — 未连接"
        fi
    done
    if ! $has_connection; then
        echo -e "  ${YELLOW}暂无活跃连接。使用 nexus connect <host> 建立连接${NC}"
    fi

    echo ""

    # SSHFS 挂载状态
    echo -e "${CYAN}[SSHFS 挂载]${NC}"
    local has_mount=false
    while IFS=$'\t' read -r host target mount_point; do
        [[ -n "$mount_point" ]] || continue
        has_mount=true

        if check_connection "$host" 2>/dev/null; then
            if [[ -n "$target" ]]; then
                echo -e "  ${GREEN}●${NC} ${host}:${target} — 已挂载 (${mount_point})"
            else
                echo -e "  ${GREEN}●${NC} ${host} — 已挂载 (${mount_point})"
            fi
        else
            if [[ -n "$target" ]]; then
                echo -e "  ${YELLOW}▲${NC} ${host}:${target} — 挂载残留，后端不可达 (${mount_point})"
            else
                echo -e "  ${YELLOW}▲${NC} ${host} — 挂载残留，后端不可达 (${mount_point})"
            fi
        fi
    done < <(list_nexus_mounts)

    if ! $has_mount; then
        echo -e "  ${YELLOW}暂无挂载。使用 nexus mount <host> [target] 挂载${NC}"
    else
        echo -e "  ${YELLOW}提示: 若显示“挂载残留，后端不可达”，请先运行 nexus umount <host>${NC}"
    fi

    echo ""
    echo -e "${CYAN}[watcher]${NC}"
    cmd_watcher status
}

cmd_mount() {
    local host="${1:?用法: nexus mount <host> [target|remote_path]}"
    local target="${2:-}"

    # 检查 sshfs 是否可用
    if ! command -v sshfs &>/dev/null; then
        echo -e "${RED}sshfs 未安装。请运行 nexus setup 安装依赖${NC}"
        return 1
    fi

    # 检查 SSH 连接
    if ! check_connection "$host"; then
        echo -e "${YELLOW}${host} 未连接，请先运行: nexus connect ${host}${NC}"
        return 1
    fi

    # 判断是 target 名称还是自定义路径
    if [[ -z "$target" ]]; then
        # 无参数：挂载配置中的默认目标
        for t in $(cfg_get_default_mounts "$host"); do
            local rpath
            rpath="$(get_remote_path "$host" "$t")"
            if [[ -n "$rpath" ]]; then
                _do_mount "$host" "$t" "$rpath"
            fi
        done
        return 0
    elif [[ "$target" == "all" ]]; then
        for t in $(get_mount_targets "$host"); do
            _do_mount "$host" "$t" "$(get_remote_path "$host" "$t")"
        done
    elif [[ "$target" == /* ]]; then
        # 绝对路径 -> 自定义挂载
        _do_mount "$host" "custom" "$target"
    else
        # target 名称（home, workspace, nfs 等）
        local rpath
        rpath="$(get_remote_path "$host" "$target")"
        if [[ -z "$rpath" ]]; then
            echo -e "${RED}${host} 没有配置 ${target} 路径${NC}"
            return 1
        fi
        _do_mount "$host" "$target" "$rpath"
    fi
}

_do_mount() {
    local host="$1" target="$2" remote_path="$3"
    local mount_point="$MOUNT_BASE/$host/$target"

    # 检查是否已挂载
    if mount | grep -q "$mount_point" 2>/dev/null; then
        echo -e "${YELLOW}[跳过] ${host}:${target} 已挂载在 ${mount_point}${NC}"
        return 0
    fi

    mkdir -p "$mount_point"

    # 展开远程 ~ 为实际路径
    if [[ "$remote_path" == "~" || "$remote_path" == "~/"* ]]; then
        local remote_home
        remote_home=$(ssh "$host" 'echo $HOME' 2>/dev/null)
        if [[ -n "$remote_home" ]]; then
            remote_path="${remote_path/#\~/$remote_home}"
        fi
    fi

    echo -e "${CYAN}挂载 ${host}:${remote_path} -> ${mount_point}${NC}"

    # SSHFS 选项，针对慢速连接优化
    sshfs "${host}:${remote_path}" "$mount_point" \
        -o reconnect \
        -o ServerAliveInterval=15 \
        -o ServerAliveCountMax=3 \
        -o follow_symlinks \
        -o noatime \
        -o auto_cache \
        -o Compression=yes

    if mount | grep -q "$mount_point" 2>/dev/null; then
        echo -e "${GREEN}[OK] ${host}:${remote_path} -> ${mount_point}${NC}"
        local mode="configured"
        [[ "$target" == "custom" ]] && mode="custom"
        restore_record_mount "$host" "$target" "$remote_path" "$mount_point" "$mode"
        watcher_start
    else
        echo -e "${RED}[FAIL] 挂载失败${NC}"
        return 1
    fi
}

cmd_umount() {
    local host="${1:?用法: nexus umount <host> [target]}"
    local target="${2:-}"
    local reason="${3:-explicit}"

    if [[ -n "$target" ]]; then
        _do_umount "$host" "$target" "$MOUNT_BASE/$host/$target" "$reason"
    else
        # 卸载该 host 下所有挂载
        local found=false
        while IFS=$'\t' read -r mount_host mount_target mount_point; do
            if [[ "$mount_host" == "$host" ]]; then
                _do_umount "$host" "$mount_target" "$mount_point" "$reason"
                found=true
            fi
        done < <(list_nexus_mounts)
        if ! $found; then
            echo -e "${YELLOW}${host} 没有活跃的挂载${NC}"
        fi
    fi
}

_do_umount() {
    local host="$1" target="$2" mount_point="$3" reason="${4:-explicit}"
    local label="${host}"
    [[ -n "$target" ]] && label="${host}:${target}"

    if ! mount | grep -q "$mount_point" 2>/dev/null; then
        echo -e "${YELLOW}${label} 未挂载${NC}"
        return 0
    fi

    echo -e "${CYAN}卸载 ${mount_point}...${NC}"

    # 多级回退卸载
    if [[ "$(uname)" == "Darwin" ]]; then
        umount "$mount_point" 2>/dev/null || \
        diskutil unmount force "$mount_point" 2>/dev/null || \
        { echo -e "${RED}[FAIL] 无法卸载 ${label}，尝试: umount -f ${mount_point}${NC}"; return 1; }
    else
        fusermount -u "$mount_point" 2>/dev/null || \
        umount "$mount_point" 2>/dev/null || \
        fusermount -uz "$mount_point" 2>/dev/null || \
        umount -l "$mount_point" 2>/dev/null || \
        { echo -e "${RED}[FAIL] 无法卸载 ${label}${NC}"; return 1; }
    fi

    echo -e "${GREEN}[OK] ${label} 已卸载${NC}"
    if [[ "$reason" == "explicit" ]]; then
        restore_remove_mount "$host" "$target"
    fi
}

cmd_restore() {
    local action="${1:-all}"
    local host_arg=""

    case "$action" in
        status)
            if restore_has_entries; then
                while IFS=$'\t' read -r host target remote_path mount_point mode; do
                    echo -e "${CYAN}${host}:${target}${NC} -> ${remote_path} (${mode})"
                done < <(restore_print_entries)
            else
                echo -e "${YELLOW}当前没有可恢复的挂载记录${NC}"
            fi
            return 0
            ;;
        clear)
            host_arg="${2:-}"
            if [[ -n "$host_arg" ]]; then
                restore_clear_host "$host_arg"
                echo -e "${GREEN}[OK] 已清空 ${host_arg} 的恢复记录${NC}"
            else
                : > "$(restore_state_file)"
                echo -e "${GREEN}[OK] 已清空所有恢复记录${NC}"
            fi
            return 0
            ;;
        all)
            ;;
        *)
            host_arg="$action"
            ;;
    esac

    if [[ -n "$host_arg" ]] && ! restore_has_entries "$host_arg"; then
        echo -e "${YELLOW}${host_arg} 没有可恢复的挂载记录${NC}"
        return 0
    elif [[ -z "$host_arg" ]] && ! restore_has_entries; then
        echo -e "${YELLOW}当前没有可恢复的挂载记录${NC}"
        return 0
    fi

    local current_host=""
    while IFS=$'\t' read -r host target remote_path mount_point mode; do
        [[ -n "$host" ]] || continue

        if [[ -n "$host_arg" && "$host" != "$host_arg" ]]; then
            continue
        fi

        if [[ "$host" != "$current_host" ]]; then
            current_host="$host"
            echo -e "${CYAN}恢复 ${host}...${NC}"
            if ! check_connection "$host" 2>/dev/null; then
                cmd_connect "$host" || continue
            fi
            if host_has_mounts "$host" && ! check_connection "$host" 2>/dev/null; then
                cmd_umount "$host" "" restore_reconcile
            fi
        fi

        if [[ "$mode" == "custom" ]]; then
            _do_mount "$host" "$target" "$remote_path"
        else
            cmd_mount "$host" "$target"
        fi
    done < <(restore_print_entries "$host_arg")
}

cmd_sync() {
    local host="${1:?用法: nexus sync <host>}"

    if ! command -v rsync &>/dev/null; then
        echo -e "${RED}rsync 未安装${NC}"
        return 1
    fi

    if ! check_connection "$host"; then
        echo -e "${YELLOW}${host} 未连接，请先运行: nexus connect ${host}${NC}"
        return 1
    fi

    local remote_path="~/code/NexusEnv"
    echo -e "${CYAN}同步 NexusEnv 到 ${host}:${remote_path}${NC}"

    ssh "$host" "mkdir -p $remote_path"
    rsync -avz --progress \
        --exclude '.git' \
        --exclude 'mounts' \
        --exclude '*.log' \
        "$SCRIPT_DIR/" "$host:$remote_path/"

    echo -e "${GREEN}[OK] 同步完成。在 ${host} 上运行:${NC}"
    echo -e "  ${CYAN}cd ${remote_path} && ./setup.sh${NC}"
}

cmd_health() {
    echo -e "${CYAN}=== 连接健康检查 ===${NC}"
    echo ""
    local all_ok=true

    for host in $(cfg_get_servers); do
        if ! check_connection "$host" 2>/dev/null; then
            echo -e "  ${RED}✗${NC} ${host} — 无连接"
            if host_has_mounts "$host"; then
                echo -e "    ${YELLOW}发现 SSHFS 挂载残留，后端不可达。请运行: nexus umount ${host}${NC}"
                all_ok=false
            fi
            continue
        fi

        # 测试连接是否真正可用（超时 5 秒）
        local start end latency
        start=$(date +%s%N 2>/dev/null || date +%s)
        if ssh -o ConnectTimeout=5 "$host" "echo ok" &>/dev/null; then
            end=$(date +%s%N 2>/dev/null || date +%s)
            if [[ "$start" =~ ^[0-9]{10,}$ ]]; then
                latency=$(( (end - start) / 1000000 ))
                echo -e "  ${GREEN}●${NC} ${host} — 正常 (${latency}ms)"
            else
                echo -e "  ${GREEN}●${NC} ${host} — 正常"
            fi
        else
            echo -e "  ${RED}✗${NC} ${host} — socket 存在但连接不可用"
            all_ok=false
            # 尝试清理无效 socket
            echo -e "    ${YELLOW}清理无效 socket...${NC}"
            ssh -S "$(get_socket_path "$host")" -O exit "$host" 2>/dev/null || cleanup_stale_socket "$host" || true
            if host_has_mounts "$host"; then
                echo -e "    ${YELLOW}发现 SSHFS 挂载残留，后端不可达。请运行: nexus umount ${host}${NC}"
            fi
        fi
    done

    echo ""
    if $all_ok; then
        echo -e "${GREEN}所有连接正常${NC}"
    else
        echo -e "${YELLOW}提示: 使用 nexus connect <host> 重建连接；若有残留挂载，先执行 nexus umount <host>${NC}"
    fi
}

cmd_ssh() {
    local host="${1:?用法: nexus ssh <host> [command...]}"
    shift

    # 检查连接，未连接则自动 connect
    if ! check_connection "$host" 2>/dev/null; then
        echo -e "${YELLOW}${host} 未连接，正在建立连接...${NC}"
        cmd_connect "$host"
    fi

    local workdir
    workdir="$(cfg_get_ssh_workdir "$host")"

    # ~ 是 ssh 默认目录，无需 cd
    [[ "$workdir" == "~" ]] && workdir=""

    if [[ $# -gt 0 ]]; then
        # 执行单条命令
        if [[ -n "$workdir" ]]; then
            ssh "$host" "cd '$workdir' && $*"
        else
            ssh "$host" "$@"
        fi
    else
        # 交互式 shell
        echo -e "${CYAN}进入 ${host} (workdir: ${workdir:-~})${NC}"
        if [[ -n "$workdir" ]]; then
            ssh -t "$host" "cd '$workdir' && exec \$SHELL -l"
        else
            ssh -t "$host"
        fi
    fi
}

generate_agent_doc() {
    local tool="$1" host="$2" remote_path="$3"
    local output_name cli_name tool_label

    case "$tool" in
        claude)
            output_name="CLAUDE.md"
            cli_name="claude"
            tool_label="Claude Code"
            ;;
        codex)
            output_name="AGENTS.md"
            cli_name="codex"
            tool_label="Codex"
            ;;
        *)
            echo -e "${RED}不支持的工具类型: ${tool}${NC}"
            return 1
            ;;
    esac

    local stype
    stype="$(cfg_get_type "$host")"
    local template_file="$SCRIPT_DIR/templates/${tool}-${stype}.md"

    if [[ ! -f "$template_file" ]]; then
        echo -e "${RED}未找到模板: ${template_file}${NC}"
        echo -e "${YELLOW}支持的类型: cloud, slurm${NC}"
        return 1
    fi

    local project_name
    project_name="$(basename "$remote_path")"

    local resolved_remote_path="$remote_path"
    if [[ "$resolved_remote_path" == "~" || "$resolved_remote_path" == "~/"* ]]; then
        if check_connection "$host" 2>/dev/null; then
            local remote_home
            remote_home=$(ssh "$host" 'echo $HOME' 2>/dev/null)
            [[ -n "$remote_home" ]] && resolved_remote_path="${resolved_remote_path/#\~/$remote_home}"
        fi
    fi

    local local_mount=""
    local output_file=""
    for target in $(get_mount_targets "$host") home; do
        local rpath
        rpath="$(get_remote_path "$host" "$target")"
        local mp="$MOUNT_BASE/$host/$target"

        if [[ "$rpath" == "~" || "$rpath" == "~/"* ]]; then
            if check_connection "$host" 2>/dev/null; then
                local remote_home
                remote_home=$(ssh "$host" 'echo $HOME' 2>/dev/null)
                [[ -n "$remote_home" ]] && rpath="${rpath/#\~/$remote_home}"
            fi
        fi

        if [[ "$resolved_remote_path" == "$rpath"* ]]; then
            local relative="${resolved_remote_path#"$rpath"}"
            local_mount="${mp}${relative}"
            break
        fi
    done

    if [[ -z "$local_mount" ]]; then
        echo -e "${YELLOW}无法确定本地挂载路径，请确保已运行 nexus mount ${host}${NC}"
        echo -e "${YELLOW}将生成到当前目录: ./${output_name}${NC}"
        local_mount="~/mnt/${host}/...${remote_path}"
        output_file="./${output_name}"
    elif [[ -d "$local_mount" ]]; then
        output_file="$local_mount/${output_name}"
    else
        echo -e "${RED}已推导出本地挂载路径，但项目目录不存在: ${local_mount}${NC}"
        echo -e "${YELLOW}请先确认远程目录存在，或先在挂载目录中创建该项目目录${NC}"
        return 1
    fi

    local content
    content=$(<"$template_file")
    content="${content//\{HOST\}/$host}"
    content="${content//\{REMOTE_PATH\}/$remote_path}"
    content="${content//\{PROJECT_NAME\}/$project_name}"
    content="${content//\{LOCAL_MOUNT\}/$local_mount}"

    if [[ -f "$output_file" ]]; then
        echo -e "${YELLOW}已存在: ${output_file}${NC}"
        read -rp "覆盖? [y/N] " ans
        [[ "$ans" != [yY]* ]] && { echo "取消。"; return 0; }
    fi

    echo "$content" > "$output_file"
    echo -e "${GREEN}[OK] ${output_name} 已生成: ${output_file}${NC}"
    echo -e "${CYAN}模板类型: ${stype}${NC}"
    echo -e ""
    echo -e "现在可以进入项目目录启动 ${tool_label}:"
    echo -e "  ${CYAN}cd $(dirname "$output_file") && ${cli_name}${NC}"
}

cmd_claude() {
    local host="${1:?用法: nexus claude <host> <remote_project_path>}"
    local remote_path="${2:?用法: nexus claude <host> <remote_project_path>}"
    generate_agent_doc claude "$host" "$remote_path"
}

cmd_codex() {
    local host="${1:?用法: nexus codex <host> <remote_project_path>}"
    local remote_path="${2:?用法: nexus codex <host> <remote_project_path>}"
    generate_agent_doc codex "$host" "$remote_path"
}

# 交互式添加单个服务器到配置文件
# 用法: _interactive_add_server <host> <config_file> <default_user>
_interactive_add_server() {
    local host="$1" config_file="$2" default_user="$3"

    # 检测远程用户
    local ruser
    ruser=$(ssh -G "$host" 2>/dev/null | awk '/^user /{print $2}')
    ruser="${ruser:-$default_user}"

    # 检测依赖
    local dep
    dep="$(_detect_proxy_dep "$host")"

    # 选择服务器类型
    local stype="cloud"
    echo -e "  ${CYAN}服务器类型:${NC}"
    echo -e "    1) cloud  — 普通云服务器（有 sudo 权限）"
    echo -e "    2) slurm  — Slurm 集群（GPU 任务通过 sbatch 提交）"
    read -rp "  选择 [1]: " type_choice
    case "${type_choice:-1}" in
        2|slurm) stype="slurm" ;;
        *) stype="cloud" ;;
    esac

    # 收集额外挂载路径
    local -a extra_mounts=()
    echo -e "  ${CYAN}默认已添加 home = ~ (远程 home 目录)${NC}"
    echo -e "  ${CYAN}如需挂载其他远程目录（如工作目录、共享存储等），请逐个添加:${NC}"
    while true; do
        echo ""
        read -rp "  挂载名称 (如 workspace、nfs，直接回车跳过): " mname
        [[ -z "$mname" ]] && break
        read -rp "  远程路径 (如 /data/${ruser}/workspace): " mpath
        if [[ -z "$mpath" ]]; then
            echo -e "  ${RED}路径不能为空，请重新输入${NC}"
            continue
        fi
        extra_mounts+=("${mname}=${mpath}")
        echo -e "  ${GREEN}+${NC} ${mname} = ${mpath} (将挂载到 ~/mnt/${host}/${mname}/)"
    done

    cfg_append_server "$config_file" "$host" "$ruser" "$dep" "$stype" "${extra_mounts[@]+"${extra_mounts[@]}"}"
    echo -e "  ${GREEN}✓${NC} 已添加 ${host} (type=${stype}, user=${ruser}${dep:+, depends=${dep}})"
}

cmd_add() {
    local host="${1:-}"
    local config_file="$NEXUS_CONFIG_FILE"

    # 确保配置文件存在
    if [[ ! -f "$config_file" ]]; then
        echo -e "${RED}未找到配置文件，请先运行: nexus init${NC}"
        return 1
    fi

    local default_user
    default_user="$(cfg_get general default_user "$(whoami)")"

    if [[ -n "$host" ]]; then
        # 指定 host 模式
        if cfg_has_server "$host"; then
            echo -e "${YELLOW}${host} 已存在于配置中${NC}"
            read -rp "重新配置? [y/N] " ans
            [[ "$ans" != [yY]* ]] && { echo "取消。"; return 0; }
        fi
        echo ""
        _interactive_add_server "$host" "$config_file" "$default_user"
    else
        # 无参数：列出未配置的 host
        echo -e "${CYAN}扫描 ~/.ssh/config 中未配置的 Host...${NC}"
        local hosts
        hosts=$(get_known_hosts)

        if [[ -z "$hosts" ]]; then
            echo -e "${YELLOW}未发现 SSH Host 配置${NC}"
            return 0
        fi

        local found=false
        for h in $hosts; do
            cfg_has_server "$h" && continue
            found=true
            echo ""
            read -rp "添加 ${h} 到 nexus 配置? [Y/n] " ans
            [[ "$ans" == [nN]* ]] && continue
            _interactive_add_server "$h" "$config_file" "$default_user"
        done

        if ! $found; then
            echo -e "${GREEN}所有 SSH Host 均已配置${NC}"
        fi
    fi

    # 重新加载配置
    cfg_load
    echo ""
    echo -e "${GREEN}配置已更新: ${config_file}${NC}"
}

cmd_set_timeout() {
    local config_file="$NEXUS_CONFIG_FILE"
    if [[ ! -f "$config_file" ]]; then
        echo -e "${RED}未找到配置文件，请先运行: nexus init${NC}"
        return 1
    fi

    local persist="${1:-}"
    if [[ -z "$persist" ]]; then
        local current
        current="$(cfg_control_persist)"
        read -rp "连接保持时间（秒，或 yes/forever）[${current}]: " persist
        persist="${persist:-$current}"
    fi

    if ! validate_control_persist "$persist"; then
        echo -e "${RED}control_persist 必须是正整数秒数，或 yes/forever${NC}"
        return 1
    fi

    [[ "$persist" == "forever" ]] && persist="yes"

    set_control_persist "$config_file" "$persist"
    cfg_load
    echo -e "${GREEN}已更新 control_persist = ${persist}${NC}"
    echo -e "${YELLOW}新设置会在下次 nexus connect 建立连接时生效；已存在连接不受影响${NC}"
}

cmd_init() {
    echo -e "${CYAN}=== NexusEnv 初始化 ===${NC}"
    echo ""

    local config_file="$NEXUS_CONFIG_FILE"
    if [[ -f "$config_file" ]]; then
        echo -e "${YELLOW}已存在配置文件: ${config_file}${NC}"
        read -rp "覆盖? [y/N] " ans
        [[ "$ans" != [yY]* ]] && { echo "取消。"; return 0; }
    fi

    # 检测当前用户
    local user
    user="$(whoami)"
    read -rp "远程默认用户名 [${user}]: " input_user
    user="${input_user:-$user}"

    local control_persist="14400"
    read -rp "连接保持时间（秒，或 yes/forever）[${control_persist}]: " input_persist
    control_persist="${input_persist:-$control_persist}"
    if ! validate_control_persist "$control_persist"; then
        echo -e "${RED}control_persist 必须是正整数秒数，或 yes/forever${NC}"
        return 1
    fi
    [[ "$control_persist" == "forever" ]] && control_persist="yes"

    local watcher_enabled="false"
    read -rp "启用 watcher 自动清理 stale 挂载? [y/N]: " input_watcher_enabled
    case "${input_watcher_enabled:-N}" in
        y|Y|yes|YES)
            watcher_enabled="true"
            ;;
        *)
            watcher_enabled="false"
            ;;
    esac

    local watcher_interval="5"
    read -rp "watcher 轮询间隔（秒）[${watcher_interval}]: " input_watcher_interval
    watcher_interval="${input_watcher_interval:-$watcher_interval}"
    if ! [[ "$watcher_interval" =~ ^[1-9][0-9]*$ ]]; then
        echo -e "${RED}watcher_interval 必须是正整数秒数${NC}"
        return 1
    fi

    local watcher_grace="10"
    read -rp "watcher 宽限时间（秒）[${watcher_grace}]: " input_watcher_grace
    watcher_grace="${input_watcher_grace:-$watcher_grace}"
    if ! [[ "$watcher_grace" =~ ^[1-9][0-9]*$ ]]; then
        echo -e "${RED}watcher_grace 必须是正整数秒数${NC}"
        return 1
    fi

    local watcher_state_dir="~/.local/state/nexus"
    read -rp "watcher 状态目录 [${watcher_state_dir}]: " input_watcher_state_dir
    watcher_state_dir="${input_watcher_state_dir:-$watcher_state_dir}"

    # 生成配置头
    cfg_write_config "$config_file" "$user" "$control_persist" "$watcher_enabled" "$watcher_interval" "$watcher_grace" "$watcher_state_dir"

    # 扫描 SSH hosts
    echo ""
    echo -e "${CYAN}扫描 ~/.ssh/config 中的 Host...${NC}"
    local hosts
    hosts=$(get_known_hosts)

    if [[ -z "$hosts" ]]; then
        echo -e "${YELLOW}未发现 SSH Host 配置${NC}"
        echo -e "配置文件已生成: ${config_file}"
        echo -e "请手动添加 [server.xxx] section"
        return 0
    fi

    for host in $hosts; do
        echo ""
        read -rp "添加 ${host} 到 nexus 配置? [Y/n] " ans
        [[ "$ans" == [nN]* ]] && continue
        _interactive_add_server "$host" "$config_file" "$user"
    done

    echo ""
    echo -e "${GREEN}配置文件已生成: ${config_file}${NC}"
    echo -e "请编辑配置文件添加 workspace/nfs 等路径:"
    echo -e "  ${CYAN}\$EDITOR ${config_file}${NC}"
}

cmd_setup() {
    bash "$SCRIPT_DIR/setup.sh"
}

cmd_help() {
    cat <<'EOF'
NexusEnv - 多机办公环境管理工具

用法: nexus <command> [args]

命令:
  connect <host>                建立 SSH ControlMaster 连接（需要2FA）
  disconnect <host>             先卸载该 host 的挂载，再关闭 SSH 连接
  ssh <host> [command...]       SSH 到服务器（自动 cd 到工作目录）
  health                        检查连接健康状态（含延迟测量）
  restore [host|action]         恢复或管理之前记录的挂载（status/clear）
  watcher <action>              管理 stale SSHFS 自动清理 watcher（start/stop/status）
  status                        查看所有连接和挂载状态
  mount <host> [target|path]    SSHFS 挂载远程目录
  umount <host> [target]        卸载 SSHFS
  claude <host> <project_path>  为远程项目生成 Claude Code 配置文件
  codex <host> <project_path>   为远程项目生成 Codex 配置文件
